{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "required_prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_prerequisites": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "ordering_constraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "dangling_references": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "internal_conflicts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "dependency_chains": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "blocking_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dependency_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "dependency_id",
          "reason"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": [
    "doc_id",
    "required_prerequisites",
    "missing_prerequisites",
    "ordering_constraints",
    "dangling_references",
    "internal_conflicts",
    "dependency_chains",
    "blocking_dependencies"
  ],
  "additionalProperties": true
}