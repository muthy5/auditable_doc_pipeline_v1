  "type": "object",
  "properties": {
    "doc_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "pass": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "stats": {
      "type": "object"
    }
  },
  "required": [
    "doc_id",
    "pass",
    "errors",
    "warnings",
    "stats"
  ],
  "additionalProperties": true
}