      "type": "string"
    },
    "doc_id": {
      "type": "string"
    },
    "index": {
      "type": "integer"
    },
    "heading_path": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "start_char": {
      "type": "integer"
    },
    "end_char": {
      "type": "integer"
    },
    "start_word": {
      "type": "integer"
    },
    "end_word": {
      "type": "integer"
    },
    "overlap_prev_words": {
