{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FallbackQueries",
  "type": "object",
  "additionalProperties": false,
  "required": ["queries"],
  "properties": {
    "queries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  }
}
