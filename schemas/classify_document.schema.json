{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "document_type": {
      "type": "string",
      "enum": [
        "business_plan",
        "legal_contract",
        "project_proposal",
        "medical_protocol",
        "technical_spec",
        "procedural_plan"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "reason": {
      "type": "string"
    }
  },
  "required": ["document_type", "confidence", "reason"],
  "additionalProperties": false
}
